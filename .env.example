# NVIDIA NIM API Key — free at https://build.nvidia.com
# Sign up → pick any free endpoint → copy your API key
VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (required for file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=development
