# ──────────────────────────────────────────────
# LearnIT — environment variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Node environment (set automatically by npm scripts)
# NODE_ENV=development

# Port for the Express server (default: 3000)
# PORT=3000

# NVIDIA NIM API key — used SERVER-SIDE ONLY for AI grading, chat, analytics
# Get one free at: https://build.nvidia.com (sign up → any model → Get API Key)
# Leave blank to use mock AI responses (fully functional demo without key)
NVIDIA_API_KEY=

# Comma-separated list of allowed CORS origins (production only)
# Example: CORS_ORIGIN=https://learnit.vercel.app
CORS_ORIGIN=

# Frontend API base URL
# Dev:  leave blank — Vite proxies /api/* to Express on :3000
# Prod: set to your Render backend URL, e.g. https://learnit-api.onrender.com
VITE_API_BASE_URL=
