# ──────────────────────────────────────────────
# LearnIT — environment variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Node environment (set automatically by npm scripts)
# NODE_ENV=development

# Port for the Express server (default: 3000)
# PORT=3000

# NVIDIA NIM API key for AI grading / chat / analytics
# Get one at: https://build.nvidia.com
# Leave blank to use mock AI responses (safe for local dev)
NVIDIA_API_KEY=

# Comma-separated list of allowed CORS origins (production only)
# Example: CORS_ORIGIN=https://learnit.vercel.app
CORS_ORIGIN=

# Frontend API base URL
# Dev:  leave blank — requests go to same origin (Express serves Vite)
# Prod: set to your backend URL, e.g. https://learnit-api.onrender.com
VITE_API_BASE_URL=
