# ── Frontend (Vite / client-side) ──────────────────────────────────────────
# Supabase project URL and anon key (safe to expose — restricted by RLS)
# Set BOTH of these in Vercel → Settings → Environment Variables
# They MUST also be listed in vite.config.ts `define` (already done) so
# Vite bakes the real values into the production bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (leave empty in dev — Vite proxy handles it)
# In production set to your Render service URL e.g. https://learn-it-xxxx.onrender.com
VITE_API_BASE_URL=

# P2-10: hCaptcha site key — get from https://dashboard.hcaptcha.com
# Leave empty to disable captcha (current default — login works without it)
# To enable: set this AND configure the matching secret key in Supabase:
#   Authentication → Settings → Bot and Abuse Protection → Enable hCaptcha
# IMPORTANT: site key and secret key must come from the SAME hCaptcha site entry.
VITE_HCAPTCHA_SITE_KEY=

# NVIDIA NIM API Key — free at https://build.nvidia.com
VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend (Express / server-side) ────────────────────────────────────────
# Supabase service role key — NEVER expose to the client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=development
