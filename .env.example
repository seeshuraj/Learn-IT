# ─── Backend (Render) ─────────────────────────────────────────────
# Get your free NVIDIA NIM key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins for CORS
# Set this to your Vercel deployment URL once deployed
CORS_ORIGIN=https://your-app.vercel.app

# Port (Render sets this automatically, do not change)
PORT=10000

NODE_ENV=production

# ─── Frontend (Vercel) ────────────────────────────────────────────
# Your Render backend URL — set this in Vercel project settings
VITE_API_BASE_URL=https://learnit-api.onrender.com

# Optional: only needed if you still use client-side AI calls (not recommended)
# VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
