# ── Frontend (Vite / client-side) ──────────────────────────────────────────
# Supabase project URL and anon key (safe to expose — restricted by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (leave empty in dev — Vite proxy handles it)
# In production set to your Render service URL e.g. https://learn-it-xxxx.onrender.com
VITE_API_BASE_URL=

# P2-10: hCaptcha site key — get from https://dashboard.hcaptcha.com
# Leave empty to disable captcha (dev / local mode)
# Must also enable hCaptcha in Supabase Auth dashboard:
#   Authentication → Settings → Bot and Abuse Protection → Enable hCaptcha
VITE_HCAPTCHA_SITE_KEY=

# NVIDIA NIM API Key — free at https://build.nvidia.com
# Sign up → pick any free endpoint → copy your API key
VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend (Express / server-side) ────────────────────────────────────────
# Supabase service role key — NEVER expose to the client
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=development
