# ──────────────────────────────────────────────
# LearnIT — environment variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Node environment (set automatically by npm scripts)
# NODE_ENV=development

# Port for the Express server (default: 3000)
# PORT=3000

# ── PostgreSQL (Supabase) ──────────────────────
# Connection string from Supabase → Project Settings → Database → Connection string (URI)
# Use the "Session" mode (port 5432) for direct connection
DATABASE_URL=

# ── NVIDIA NIM ─────────────────────────────────
# Used SERVER-SIDE ONLY for AI grading, chat, analytics
# Get one free at: https://build.nvidia.com
# Leave blank to use mock AI responses
NVIDIA_API_KEY=

# ── Frontend (Vite) ────────────────────────────
# Your Render backend URL for production
# Dev: leave blank — Vite proxies /api/* to Express on :3000
VITE_API_BASE_URL=

# Supabase project URL and publishable key (for future client-side auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
